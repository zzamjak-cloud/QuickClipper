rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // 로그인한 사용자인지 확인
    function isSignedIn() {
      return request.auth != null;
    }

    // 접근 제어 설정 문서 (config/access: { admins: [...], allowed: [...] })
    function accessData() {
      return get(/databases/$(database)/documents/config/access).data;
    }

    // 관리자 여부
    function isAdmin() {
      return isSignedIn() && request.auth.token.email in accessData().admins;
    }

    // 허용된 계정 여부 (관리자는 항상 허용)
    function isAllowed() {
      return isSignedIn()
        && (request.auth.token.email in accessData().allowed
            || request.auth.token.email in accessData().admins);
    }

    // 본인 데이터인지 확인
    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    // 접근 제어 설정: 관리자만 읽기/수정 (설정 팝업에서 이메일 추가/제거)
    match /config/access {
      allow read, write: if isAdmin();
    }

    // 일일 다이제스트: 허용된 계정만 읽기 (쓰기는 수집기의 Admin SDK가 규칙을 우회하여 수행)
    match /digests/{date} {
      allow read: if isAllowed();
      allow write: if false;

      match /items/{itemId} {
        allow read: if isAllowed();
        allow write: if false;
      }
    }

    // 게임 순위: 허용된 계정만 읽기 (쓰기는 수집기의 Admin SDK)
    match /rankings/{date} {
      allow read: if isAllowed();
      allow write: if false;

      match /charts/{chartId} {
        allow read: if isAllowed();
        allow write: if false;
      }
    }

    // 수집 소스 정의: 허용된 계정 읽기, 관리자만 편집 (설정 UI에서 추가/제거)
    match /sources/{sourceId} {
      allow read: if isAllowed();
      allow write: if isAdmin();
    }

    // 사용자 개인 데이터(스크랩, 설정): 허용된 계정 + 본인만
    match /users/{uid}/{document=**} {
      allow read, write: if isAllowed() && isOwner(uid);
    }
  }
}
